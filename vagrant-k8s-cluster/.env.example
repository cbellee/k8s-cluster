# Copy to .env and adjust for your environment.
# This file is sourced by scripts and parsed by Vagrantfile.

# Base image
IMAGE=bento/ubuntu-26.04

# Networking
BRIDGE=br0
NETMASK=255.255.255.0
GATEWAYIP=192.168.89.1
DNS0IP=192.168.89.1

# Libvirt/QEMU
DISKPATH=/mnt/vmm
KVM_DRIVER=kvm
MGMT_NETWORK_NAME=vagrant_mgmt_network
MGMT_NETWORK_CIDR=192.168.121.0/24

# Cluster endpoint alias and preferred default target
CP_ENDPOINT_ALIAS=kube-cluster-01
CP_ENDPOINT_NODE=kube-cp-01
CP_ENDPOINT_IP=192.168.89.10

# Kubernetes and Cilium versions
K8S_VERSION=1.35.6
K8S_CHANNEL=1.35
CILIUM_VERSION=1.18.3

# Node sizing and addressing
CP01_CPUS=2
CP01_MEM=4096
CP01_IP=192.168.89.10

CP02_CPUS=2
CP02_MEM=4096
CP02_IP=192.168.89.11

CP03_CPUS=2
CP03_MEM=4096
CP03_IP=192.168.89.12

WK01_CPUS=2
WK01_MEM=4096
WK01_IP=192.168.89.20

WK02_CPUS=2
WK02_MEM=4096
WK02_IP=192.168.89.21

WK03_CPUS=2
WK03_MEM=4096
WK03_IP=192.168.89.22
